{
  "ipas_112_format": {
    "description": "適用於 iPAS AI 112 年官方發布之試題排版",
    "start_anchor": "模擬考題", 
    "cleaning_rules": [
      { "pattern": "[^\\n]*[^\\n]*\\n", "repl": "\\n" },
      { "pattern": "\\n\\s*[A-Za-z0-9]+-\\d+\\s*\\n", "repl": "\\n" },
      { "pattern": "([。！？])\\s*(\\d+\\.\\d+)", "repl": "\\1\\n\\2" },
      { "pattern": "([。！？])\\s*(大數據|參考文獻)", "repl": "\\1\\n\\2" }
    ],
    "question_pattern": "(?:^|\\n)\\s*(\\d+)\\.\\s+(?!Ans)((?:(?![\\(（]A[\\)）]|\\n\\s*\\d+\\.).)*?)[\\(（]A[\\)）]\\s*((?:(?![\\(（]B[\\)）]|\\n\\s*\\d+\\.).)*?)[\\(（]B[\\)）]\\s*((?:(?![\\(（]C[\\)）]|\\n\\s*\\d+\\.).)*?)[\\(（]C[\\)）]\\s*((?:(?![\\(（]D[\\)）]|\\n\\s*\\d+\\.).)*?)[\\(（]D[\\)）]\\s*(.*?)\\s*(?=\\n\\s*\\d+\\.\\s|\\n\\s*\\d+\\.\\s*Ans|$)",
    "answer_pattern": "(?:^|\\n)\\s*(\\d+)\\.\\s*Ans\\s*[\\(（]([A-D])[\\)）][^\\n]*(?:\\n\\s*解析[：:]\\s*)?((?:(?!\\n\\s*\\d+\\.\\s*Ans|\\n\\s*\\d+\\.\\d+|\\n\\s*大數據|\\n\\s*參考文獻).)*)"
  }
}