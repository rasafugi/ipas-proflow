      { "pattern": "([。！？])\\s*(\\d+\\.\\d+)", "repl": "\\1\\n\\2" },
      { "pattern": "([。！？])\\s*(大數據|參考文獻)", "repl": "\\1\\n\\2" }
    ],
    "question_pattern": "(?:^|\\s+)(?P<q_num>\\d+)\\.\\s*(?!Ans)(?P<question>(?:(?!\\s+\\d+\\.(?!\\d)|\\s*[\\(（]\\s*[AＡ]\\s*[\\)）]).)*?)\\s*[\\(（]\\s*[AＡ]\\s*[\\)）]\\s*(?P<A>(?:(?!\\s+\\d+\\.(?!\\d)|\\s*[\\(（]\\s*[BＢ]\\s*[\\)）]).)*?)\\s*[\\(（]\\s*[BＢ]\\s*[\\)）]\\s*(?P<B>(?:(?!\\s+\\d+\\.(?!\\d)|\\s*[\\(（]\\s*[CＣ]\\s*[\\)）]).)*?)\\s*[\\(（]\\s*[CＣ]\\s*[\\)）]\\s*(?P<C>(?:(?!\\s+\\d+\\.(?!\\d)|\\s*[\\(（]\\s*[DＤ]\\s*[\\)）]).)*?)\\s*[\\(（]\\s*[DＤ]\\s*[\\)）]\\s*(?P<D>(?:(?!\\s+\\d+\\.(?!\\d)).)*?)\\s*(?=\\s+\\d+\\.(?!\\d)|$)",
    "answer_pattern": "(?:^|\\s+)(?P<q_num>\\d+)\\.\\s*Ans\\s*[\\(（](?P<ans>[A-D])[\\)）][^\\n]*(?:\\n\\s*解析[：:]\\s*)?(?P<exp>(?:(?!\\s+\\d+\\.\\s*Ans|\\s+\\d+\\.\\d+|\\s+大數據|\\s+參考文獻).)*)"
  },
  "ipas_114_official": {
